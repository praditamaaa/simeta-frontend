  "info": {
    "title": "SIMETA API",
    "description": "SIMETA (Sistem Informasi Mentoring Tahfidz) — Enterprise API Documentation.\n\n## Authentication\nMost endpoints require a JWT Bearer token. Use `/api/v1/auth/login` to obtain a token.\n\n## Roles\n- **ADMIN**: Full system access\n- **DOSEN**: Lecturer access (mentoring, quizzes, news)\n- **MENTOR**: Mentor access (mentoring reports)\n- **MAHASISWA**: Student access (personal data)",
    "version": "1.0.0",
    "contact": {
      "name": "SIMETA Team",
      "url": "",
      "email": "admin@simeta.id"
    },
    "license": {
      "name": "UNLICENSED",
      "url": ""
    }
  },
  "tags": [
    {
      "name": "Health",
      "description": "Application health check"
    },
    {
      "name": "Auth",
      "description": "Authentication & registration"
    },
    {
      "name": "Users",
      "description": "User management (Admin only)"
    },
    {
      "name": "Attendance",
      "description": "Attendance & session management"
    },
    {
      "name": "Mentoring",
      "description": "Mentoring reports & mentee management"
    },
    {
      "name": "Quiz",
      "description": "Quiz creation, submission & results"
    },
    {
      "name": "Permission",
      "description": "Permission/leave requests"
    },
    {
      "name": "Resume",
      "description": "Student resume management"
    },
    {
      "name": "Dashboard",
      "description": "Grades & student dashboard"
    },
    {
      "name": "Notification",
      "description": "User notifications"
    },
    {
      "name": "News",
      "description": "News & announcements"
    }
  ],
  "servers": [],
  "components": {
    "securitySchemes": {
      "JWT-auth": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http",
        "description": "Enter your JWT token"
      }
    },
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "minLength": 6
          }
        },
        "required": [
          "name",
          "email",
          "password"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string"
          },
          "deviceId": {
            "type": "string"
          }
        },
        "required": [
          "email",
          "password",
          "deviceId"
        ]
      },
      "AssignRoleDto": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "ADMIN",
              "DOSEN",
              "MENTOR",
              "MAHASISWA"
            ]
          }
        },
        "required": [
          "role"
        ]
      },
      "CreateSessionDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "startTime": {
            "type": "string"
          },
          "endTime": {
            "type": "string"
          }
        },
        "required": [
          "title",
          "startTime",
          "endTime"
        ]
      },
      "CreateAttendanceDto": {
        "type": "object",
        "properties": {
          "sessionId": {
            "type": "string",
            "format": "uuid"
          },
          "latitude": {
            "type": "number"
          },
          "longitude": {
            "type": "number"
          }
        },
        "required": [
          "sessionId",
          "latitude",
          "longitude"
        ]
      },
      "UpdateAttendanceDto": {
        "type": "object",
        "properties": {}
      },
      "MemorizationRecordDto": {
        "type": "object",
        "properties": {
          "studentId": {
            "type": "string"
          },
          "surahName": {
            "type": "string"
          },
          "ayatStart": {
            "type": "number"
          },
          "ayatEnd": {
            "type": "number"
          },
          "fluency": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          }
        },
        "required": [
          "studentId",
          "surahName",
          "ayatStart",
          "ayatEnd",
          "fluency"
        ]
      },
      "CreateMentoringReportDto": {
        "type": "object",
        "properties": {
          "groupId": {
            "type": "string",
            "format": "uuid"
          },
          "date": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "memorizationRecords": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MemorizationRecordDto"
            }
          }
        },
        "required": [
          "groupId",
          "date",
          "memorizationRecords"
        ]
      },
      "CreateQuestionDto": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "options": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "correctIdx": {
            "type": "number",
            "minimum": 0
          }
        },
        "required": [
          "text",
          "options",
          "correctIdx"
        ]
      },
      "CreateQuizDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "PRETEST",
              "POSTTEST"
            ]
          },
          "questions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CreateQuestionDto"
            }
          }
        },
        "required": [
          "title",
          "type",
          "questions"
        ]
      },
      "AnswerDto": {
        "type": "object",
        "properties": {
          "questionId": {
            "type": "string",
            "format": "uuid"
          },
          "selectedIdx": {
            "type": "number",
            "minimum": 0
          }
        },
        "required": [
          "questionId",
          "selectedIdx"
        ]
      },
      "SubmitQuizDto": {
        "type": "object",
        "properties": {
          "answers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AnswerDto"
            }
          }
        },
        "required": [
          "answers"
        ]
      },
      "CreatePermissionDto": {
        "type": "object",
        "properties": {
          "reason": {
            "type": "string"
          },
          "sessionId": {
            "type": "string",
            "format": "uuid"
          },
          "proofUrl": {
            "type": "string"
          }
        },
        "required": [
          "reason"
        ]
      },
      "CreateResumeDto": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string",
            "minLength": 200
          },
          "fileUrl": {
            "type": "string"
          }
        },
        "required": [
          "content"
        ]
      },
      "UpdateResumeDto": {
        "type": "object",
        "properties": {}
      },
      "CreateNewsDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "imageUrl": {
            "type": "string"
          }
        },
        "required": [
          "title",
          "content"
        ]
      }
    }
  }
}